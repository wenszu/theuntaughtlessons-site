rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function signedInWithEmail() {
      return signedIn() &&
        request.auth.token.email_verified == true &&
        request.auth.token.email is string;
    }

    function isSelfUserDocument(userId) {
      return signedIn() && (
        request.auth.uid == userId ||
        (signedInWithEmail() && request.auth.token.email.lower() == userId.lower())
      );
    }

    function isAdmin() {
      return signedInWithEmail() &&
        get(/databases/$(database)/documents/authorized_members/$(request.auth.token.email.lower())).data.role in ['admin', 'owner'];
    }

    match /users/{userId} {
      allow read: if isSelfUserDocument(userId) || isAdmin();
      allow write: if isSelfUserDocument(userId);
    }

    match /users/{userId}/completed_exercises/{exerciseId} {
      allow read: if (signedIn() && request.auth.uid == userId) || isAdmin();
      allow write: if signedIn() && request.auth.uid == userId;
    }

    match /authorized_members/{email} {
      allow read: if signedIn();
      allow write: if isAdmin();
      // Members can update only their own preferred name (set during onboarding)
      allow update: if signedInWithEmail() &&
        request.auth.token.email.lower() == email &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name']);
    }

    match /access_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
